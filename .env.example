# Copy to .env and fill in before running docker compose up.
# .env is gitignored — never commit real values.

# Short slug used for the Hermes profile, container name, and Kanban board.
PROJECT_NAME=my-project

# Absolute host path to the target project's git repo (Tier 3 mount).
# This gets bind-mounted read/write into the container at
# /workspace/${PROJECT_NAME}. Kanban worker tasks use git worktrees inside
# this mount for per-task isolation (see docs/MOUNTS.md).
PROJECT_REPO_PATH=/absolute/path/to/target/project

# Z.ai / GLM credentials. Rotate this — the value that used to live
# hardcoded in D:\code\eng-team-plugin\.mcp.json is compromised (committed
# to git in plaintext) and should not be reused here.
Z_AI_API_KEY=replace-me

# Pin to a specific release tag once you've validated one, rather than
# tracking `latest` — see https://github.com/NousResearch/hermes-agent/releases
HERMES_IMAGE_TAG=latest
