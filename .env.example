# Copy to .env and fill in before running docker compose up.
# .env is gitignored — never commit real values.

# Short slug used for the Hermes profile, container name, and Kanban board.
PROJECT_NAME=my-project

# Absolute host path to the target project's git repo (Tier 3 mount).
# This gets bind-mounted read/write into the container at
# /workspace/${PROJECT_NAME}. Kanban worker tasks use git worktrees inside
# this mount for per-task isolation (see docs/MOUNTS.md).
PROJECT_REPO_PATH=/absolute/path/to/target/project

# Z.ai / GLM credentials. Rotate this — the value that used to live
# hardcoded in D:\code\eng-team-plugin\.mcp.json is compromised (committed
# to git in plaintext) and should not be reused here.
#
# This must be the REAL Z.AI key. It's used directly (not via the LiteLLM
# proxy below) by config/config.yaml's mcp_servers.zai-vision and
# zai-web-search — those two MCP tools call real Z.AI endpoints and are not
# proxied. Do not put a LiteLLM virtual key here.
Z_AI_API_KEY=replace-me

# The main chat model's credential (2026-07-03: routed through the team's
# LiteLLM proxy for per-team token-usage tracking via virtual keys). Put
# this project's LiteLLM virtual key here, NOT a real Z.AI key. Hermes's
# built-in "zai" provider checks GLM_API_KEY before Z_AI_API_KEY (see
# docker-compose.yml's comment for the confirmed source-level precedence),
# so this is what the main chat model actually uses — Z_AI_API_KEY above
# stays reserved for the two direct-to-Z.AI MCP tools.
GLM_API_KEY=replace-me

# Base URL for the main chat model (2026-07-03: the team's LiteLLM proxy,
# not api.z.ai directly — see docker-compose.yml's comment for why this
# env var specifically, not just config.yaml's model.base_url).
GLM_BASE_URL=https://litellm.home.zirkler.com/v1

# Pin to a specific release tag once you've validated one, rather than
# tracking `latest` — see https://github.com/NousResearch/hermes-agent/releases
HERMES_IMAGE_TAG=latest

# Dashboard basic-auth (mandatory as of Hermes's June 2026 hardening for
# any non-loopback bind — and the dashboard binds 0.0.0.0 INSIDE the
# container by default, since a container-internal 127.0.0.1 bind can't be
# reached via a published port at all). This is the bundled zero-infra
# option for a local/trusted-network box, per the official docs.
HERMES_DASHBOARD_USERNAME=damon
HERMES_DASHBOARD_PASSWORD=replace-me
HERMES_DASHBOARD_SECRET=replace-me-with-a-random-string

# --- MCP servers ported 2026-07-03 from the global VS Code user-level MCP
# config (C:\Users\damon\AppData\Roaming\Code\User\mcp.json) — see
# config/config.yaml's mcp_servers block for how each is wired up.

# GitHub's Copilot-hosted remote MCP (config.yaml's mcp_servers.github)
# authenticates via VS Code's own Copilot OAuth session there; headless
# here, so it needs a Copilot-entitled personal access token instead.
# Also used, since 2026-07-04, by bootstrap to set up real `git push`/`gh
# pr create` auth in-container (`gh auth login --with-token` + `gh auth
# setup-git`, no SSH key needed) — see docs/MOUNTS.md's Tier 3 section.
# Needs `repo` scope for that to work, not just Copilot entitlement.
GITHUB_TOKEN=replace-me

# Self-hosted Firecrawl instance (mcp_servers.firecrawl). URL isn't
# secret; key is.
FIRECRAWL_API_URL=https://firecrawl.home.zirkler.com
FIRECRAWL_API_KEY=replace-me

# Memlord memory service (mcp_servers.memlord).
MEMLORD_API_KEY=replace-me

# NOTE: mcp_servers.zread and .token-tracker need no new keys here —
# zread reuses Z_AI_API_KEY above, and token-tracker carries no auth
# header even in the source global config (internal-network trust).

# --- Discord gateway platform (2026-07-05) — talk to the orchestrator from
# Discord instead of `docker exec -it <container> hermes`. See
# config/config.yaml's `discord:` block for the session/notification
# behavior this enables. Setup:
#   1. https://discord.com/developers/applications -> New Application -> Bot
#      -> under Privileged Gateway Intents, enable "Message Content Intent"
#      (silent-bot failures almost always trace back to this) -> Reset
#      Token, paste it below.
#   2. OAuth2 -> URL Generator -> scopes: bot -> permissions: Send Messages,
#      Create Public Threads, Send Messages in Threads, Read Message
#      History -> open the generated URL to invite it to your server.
#   3. Enable Developer Mode in Discord (User Settings -> Advanced), then
#      right-click your own name -> Copy User ID -> paste below. Without
#      this, the bot needs DISCORD_ALLOW_ALL_USERS=true to answer anyone.
DISCORD_BOT_TOKEN=replace-me
DISCORD_ALLOWED_USERS=replace-me
# Optional catch-all channel ID for notifications not tied to a specific
# thread (right-click a channel -> Copy Channel ID). Leave blank to skip.
DISCORD_HOME_CHANNEL=
