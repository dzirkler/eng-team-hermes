# Real secrets / local overrides — never commit
.env

# Tier-2 writable state — Hermes's ENTIRE /opt/data tree (config, .env,
# SOUL.md, sessions, memories, skills, home, cron, hooks, logs) lands here
# as one unit; that's Hermes's real persistence contract, not the
# subdivided kanban/memory/credentials split originally assumed. Kept out
# of git so the repo stays a clean description of "how to build the team,"
# not an accumulating dump of one instance's runtime state.
state/data/

# Keep the directory structure itself trackable
!state/**/.gitkeep
